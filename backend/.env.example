OSTICKET_URL_LOGIN=https://mesadepartes.uandina.edu.pe/scp/login.php
OSTICKET_USER=usuario@uandina.edu.pe
OSTICKET_PASSWORD=coloca-la-clave-en-backend/.env-o-en-systemd
OSTICKET_AUTH_FILE=/opt/sistema_posgrado/backend/auth.json

DB_URL=mysql+pymysql://usuario:password@localhost/bot_epg

SMTP_HOST=smtp.uandina.edu.pe
SMTP_PORT=587
SMTP_USER=usuario@uandina.edu.pe
SMTP_PASSWORD=coloca-la-clave-o-app-password
SMTP_FROM=Escuela de Posgrado <usuario@uandina.edu.pe>

EPG_UPLOADS_DIR=/opt/sistema_posgrado/uploads/expedientes
EPG_PRIVATE_UPLOADS_DIR=/opt/sistema_posgrado/uploads_privados
EPG_UPLOADS_PUBLIC_URL=https://dataepis.uandina.pe:49267/expedientes

# Seguridad de E1. En produccion usar valores reales fuera de Git.
EPG_ENVIRONMENT=production
JWT_SECRET_KEY=generar-con-openssl-rand-hex-48
EPG_ALLOWED_ORIGINS=https://dataepis.uandina.pe:49267,http://localhost:5173
EPG_OUTBOUND_ACTIONS_ENABLED=false
# Compatibilidad temporal para cuentas sin clave. Retirar solo con aprobacion institucional.
EPG_LEGACY_PASSWORD_LOGIN_ENABLED=true
EPG_LEGACY_PASSWORD_RETIREMENT_DATE=2026-10-31

# Inicio de sesión con Google Workspace. Crear un cliente OAuth propio para Posgrado;
# nunca reutilizar ni versionar secretos de otro sistema.
EPG_GOOGLE_OAUTH_ENABLED=false
EPG_GOOGLE_CLIENT_ID=
EPG_GOOGLE_CLIENT_SECRET=
EPG_GOOGLE_ALLOWED_DOMAIN=uandina.edu.pe
EPG_GOOGLE_DRIVE_OWNER_EMAILS=epg_tramites@uandina.edu.pe
EPG_OAUTH_SESSION_SECRET=generar-con-openssl-rand-hex-48
EPG_PUBLIC_BASE_URL=https://dataepis.uandina.pe:49267
EPG_PUBLIC_API_PREFIX=/bot-posgrado
