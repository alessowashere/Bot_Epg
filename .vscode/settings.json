{
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/venv/**": true,
    "**/.venv/**": true,
    "**/__pycache__/**": true,
    "**/.pytest_cache/**": true,
    "**/.mypy_cache/**": true,
    "**/.ruff_cache/**": true,
    "**/uploads/**": true,
    "**/media/**": true,
    "**/logs/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/.next/**": true,
    "**/coverage/**": true,
    "**/data/drive_evidencia/**": true,
    "**/data/drive_resoluciones/**": true,
    "**/data/tickets/**": true,
    "**/data/reportes/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/venv": true,
    "**/.venv": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/uploads": true,
    "**/media": true,
    "**/logs": true,
    "**/dist": true,
    "**/build": true,
    "**/.next": true,
    "**/coverage": true,
    "**/data/drive_evidencia": true,
    "**/data/drive_resoluciones": true,
    "**/data/tickets": true,
    "**/data/reportes": true
  },
  "git.autorefresh": false,
  "git.autofetch": false,
  "git.untrackedChanges": "mixed",
  "git.openRepositoryInParentFolders": "never",
  "typescript.disableAutomaticTypeAcquisition": true
}
