[Unit]
Description=FastAPI Bot Posgrado EPG-UAC
After=network.target

[Service]
User=root
WorkingDirectory=/opt/sistema_posgrado/backend
Environment="PATH=/opt/sistema_posgrado/backend/venv/bin"
# Inicia uvicorn anclado al entorno virtual, escuchando en el puerto 8000
ExecStart=/opt/sistema_posgrado/backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
